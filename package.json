  "keywords": ["claude", "mcp", "telegram", "ask-user", "inline-keyboard", "grammy", "telegraf"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.78",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "grammy": ">=1.0.0",
    "telegraf": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "grammy": { "optional": true },
    "telegraf": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "grammy": "^1.31.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
