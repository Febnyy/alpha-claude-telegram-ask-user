{
  "name": "alpha-claude-telegram-ask-user",
  "version": "0.1.0",
  "description": "MCP bridge: Claude Agent SDK ask_user tool -> Telegram inline keyboards",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch"
